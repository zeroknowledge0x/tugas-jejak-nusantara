{
	"name": "JejakNusantara",
	"globIgnorePaths": [
		"**/_*.luau",
		"docs/**",
		"tooling/**"
	],
	"tree": {
		"$className": "DataModel",
		"ReplicatedStorage": {
			"$className": "ReplicatedStorage",
			"JN": {
				"$className": "Folder",
				"Modules": {
					"$path": "src/ReplicatedStorage/Modules"
				}
			}
		},
		"ServerScriptService": {
			"$className": "ServerScriptService",
			"$path": "src/ServerScriptService"
		},
		"StarterPlayer": {
			"$className": "StarterPlayer",
			"StarterPlayerScripts": {
				"$className": "StarterFolder",
				"$path": "src/StarterPlayer/StarterPlayerScripts"
			}
		},
		"Workspace": {
			"$className": "Workspace",
			"$path": "src/Workspace"
		},
		"SoundService": {
			"$className": "SoundService"
		},
		"Lighting": {
			"$className": "Lighting"
		},
		"TextChatService": {
			"$className": "TextChatService"
		}
	}
}