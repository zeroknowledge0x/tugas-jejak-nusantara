          <Item class="ModuleScript" referent="48">
            <Properties>
              <string name="Name">RNG</string>
              <string name="Source"><![CDATA[--! RNG.luau
--! Seedable RNG wrapper for deterministic mini-game layouts / secrets.

local RNG = {}
RNG.__index = RNG

function RNG.new(seed: number?)
	local self = setmetatable({}, RNG) :: any
	self._rng = Random.new(seed or os.clock())
	return self
end

function RNG:NextInteger(min: number, max: number): number
	return self._rng:NextInteger(min, max)
end

function RNG:NextNumber(min: number?, max: number?): number
	return self._rng:NextNumber(min or 0, max or 1)
end

-- Convenience: 0..1 float (used by mini-game layout generators).
function RNG:Next(): number
	return self._rng:NextNumber()
end

function RNG:Pick<T>(list: { T }): T
	return list[self._rng:NextInteger(1, #list)]
end

function RNG:Shuffle<T>(list: { T }): { T }
	local out = table.clone(list)
	for i = #out, 2, -1 do
		local j = self._rng:NextInteger(1, i)
		out[i], out[j] = out[j], out[i]
	end
	return out
end

return RNG
]]></string>
            </Properties>
          </Item>
          <Item class="ModuleScript" referent="49">
            <Properties>
              <string name="Name">Signal</string>
              <string name="Source"><![CDATA[--! Signal.luau
--! Minimal typed signal (event emitter) for decoupled system communication.

export type Connection = {
	Disconnect: (self: Connection) -> (),
}

export type Signal<T...> = {
	Connect: (self: Signal<T...>, fn: (T...) -> ()) -> Connection,
	Fire: (self: Signal<T...>, T...) -> (),
	Wait: (self: Signal<T...>) -> T...,
	Destroy: (self: Signal<T...>) -> (),
	_disconnectAll: (self: Signal<T...>) -> (),
}

type Listener = {
	fn: any,
	next: Listener?,
}

local Signal = {}
Signal.__index = Signal

function Signal.new<T...>(): Signal<T...>
	local self = setmetatable({}, Signal) :: any
	self._head = nil :: Listener?
	self._yield = nil :: { (T...) -> () }?
	return self
end

function Signal:Connect(fn)
	local node = { fn = fn, next = nil } :: Listener
	if self._head == nil then
		self._head = node
	else
		local cur = self._head
		while cur.next do
			cur = cur.next
		end
		cur.next = node
	end
	local conn = {
		Disconnect = function()
			self:_remove(node)
		end,
	}
	return conn
end

function Signal:Fire(...)
	local cur = self._head
	while cur do
		(cur.fn)(...)
		cur = cur.next
	end
end

function Signal:Wait()
	local thread = coroutine.running()
	self._yield = self._yield or {}
	table.insert(self._yield, thread)
	return coroutine.yield()
end

function Signal:_remove(node)
	local cur = self._head
	local prev: Listener? = nil
	while cur do
		if cur == node then
			if prev == nil then
				self._head = cur.next
			else
				prev.next = cur.next
			end
			return
		end
		prev = cur
		cur = cur.next
	end
end

function Signal:_disconnectAll()
	self._head = nil
	self._yield = nil
end

function Signal:Destroy()
	self:_disconnectAll()
end

return Signal
]]></string>
            </Properties>
          </Item>
          <Item class="ModuleScript" referent="50">
            <Properties>
              <string name="Name">Table</string>
              <string name="Source"><![CDATA[--! Table.luau
--! Small table utilities. Avoids reimplementing in every system.

local Table = {}

function Table.clone<T>(t: { [any]: T }): { [any]: T }
	local out = {}
	for k, v in pairs(t) do
		out[k] = v
	end
	return out
end

function Table.keys<T>(t: { [any]: T }): { any }
	local out = {}
	for k, _ in pairs(t) do
		table.insert(out, k)
	end
	return out
end

function Table.count(t: { [any]: any }): number
	local n = 0
	for _, _ in pairs(t) do
		n += 1
	end
	return n
end

function Table.shallowEqual(a: { [any]: any }, b: { [any]: any }): boolean
	if Table.count(a) ~= Table.count(b) then
		return false
	end
	for k, v in pairs(a) do
		if b[k] ~= v then
			return false
		end
	end
	return true
end

function Table.firstKey<T>(t: { [any]: T }): any
	for k, _ in pairs(t) do
		return k
	end
	return nil
end

return Table
]]></string>
            </Properties>
          </Item>
          <Item class="ModuleScript" referent="51">
            <Properties>
              <string name="Name">Tween</string>
              <string name="Source"><![CDATA[--! Tween.luau
--! Tween helpers with sane defaults and cleanup tracking.

local TweenService = game:GetService("TweenService")

export type TweenOpts = {
	time: number?,
	easingStyle: Enum.EasingStyle?,
	easingDirection: Enum.EasingDirection?,
	repeatCount: number?,
	reverses: boolean?,
	delayTime: number?,
	completed: (() -> ())?,
}

local function defaultOpts(opts: TweenOpts?): TweenInfo
	local o = opts or {}
	return TweenInfo.new(
		o.time or 0.3,
		o.easingStyle or Enum.EasingStyle.Quad,
		o.easingDirection or Enum.EasingDirection.Out,
		o.repeatCount or 0,
		o.reverses or false,
		o.delayTime or 0
	)
end

local Tween = {}

function Tween.create(instance: Instance, props: { [string]: any }, opts: TweenOpts?): TweenBase
	return TweenService:Create(instance, defaultOpts(opts), props)
end

function Tween.play(instance: Instance, props: { [string]: any }, opts: TweenOpts?): TweenBase
	local t = Tween.create(instance, props, opts)
	t:Play()
	return t
end

-- Convenience used by UI fades. Mirrors Tween.play + optional completed callback.
function Tween.To(instance: Instance, props: { [string]: any }, opts: TweenOpts?): TweenBase
	local o = opts or {}
	local t = Tween.create(instance, props, o)
	if o.completed ~= nil then
		t.Completed:Connect(o.completed)
	end
	t:Play()
	return t
end

return Tween
]]></string>
            </Properties>
          </Item>
        </Item>
      </Item>
    </Item>
